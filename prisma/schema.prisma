// Aspire Studio — Multi-tenant Prisma Schema
// Derived from docs/DB_SCHEMA.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── IDENTITY ──────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique @map("clerk_id")
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  role      String   @default("user")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  lastSeen  DateTime? @map("last_seen")

  orgMembers     OrganizationMember[]
  projectMembers ProjectMember[]
  createdProjects Project[]       @relation("ProjectCreator")
  templates      Template[]       @relation("TemplateCreator")
  assets         Asset[]          @relation("AssetCreator")
  changeHistory  ChangeHistory[]  @relation("ChangeActor")
  auditLogs      AuditLog[]       @relation("AuditActor")

  @@map("users")
}

// ─── ORGANIZATIONS (tenants) ───────────────────────────

model Organization {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  billingInfo Json?    @map("billing_info")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members       OrganizationMember[]
  projects      Project[]
  subscriptions Subscription[]
  generations   Generation[]
  artifacts     Artifact[]
  assets        Asset[]
  usageRecords  UsageRecord[]
  invoices      Invoice[]
  payments      Payment[]
  changeHistory ChangeHistory[]
  auditLogs     AuditLog[]

  @@map("organizations")
}

model OrganizationMember {
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  role      String   // owner, admin, developer, viewer
  createdAt DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orgId, userId])
  @@map("organization_members")
}

// ─── PROJECTS ──────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  name        String
  slug        String
  description String?
  settings    Json     @default("{}")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator User?        @relation("ProjectCreator", fields: [createdBy], references: [id])

  members       ProjectMember[]
  apiKeys       ApiKey[]
  templates     Template[]
  generations   Generation[]
  artifacts     Artifact[]
  assets        Asset[]
  deployments   Deployment[]
  usageRecords  UsageRecord[]
  changeHistory ChangeHistory[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("projects")
}

model ProjectMember {
  projectId String @map("project_id")
  userId    String @map("user_id")
  role      String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_members")
}

// ─── API KEYS ──────────────────────────────────────────

model ApiKey {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  keyHash     String   @map("key_hash")
  description String?
  scopes      String[]
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("api_keys")
}

// ─── TEMPLATES ─────────────────────────────────────────

model Template {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  name        String
  description String?
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator  User?             @relation("TemplateCreator", fields: [createdBy], references: [id])
  versions TemplateVersion[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("templates")
}

model TemplateVersion {
  id              String   @id @default(cuid())
  templateId      String   @map("template_id")
  version         Int
  prompt          String
  variablesSchema Json?    @map("variables_schema")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  template    Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  generations Generation[]

  @@unique([templateId, version])
  @@map("template_versions")
}

// ─── GENERATIONS (jobs) ────────────────────────────────

model Generation {
  id                String    @id @default(cuid())
  orgId             String    @map("org_id")
  projectId         String    @map("project_id")
  templateVersionId String?   @map("template_version_id")
  jobType           String    @map("job_type")  // branding, ui, code, blueprint, image, embeddings
  status            String    @default("pending") // pending, running, succeeded, failed, cancelled
  input             Json?
  options           Json?
  priority          Int       @default(0)
  error             String?
  startedAt         DateTime? @map("started_at")
  finishedAt        DateTime? @map("finished_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  org             Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateVersion TemplateVersion? @relation(fields: [templateVersionId], references: [id])
  artifacts       Artifact[]
  usageRecords    UsageRecord[]

  @@index([projectId])
  @@index([status])
  @@map("generations")
}

// ─── ARTIFACTS ─────────────────────────────────────────

model Artifact {
  id           String   @id @default(cuid())
  generationId String   @map("generation_id")
  projectId    String   @map("project_id")
  orgId        String   @map("org_id")
  type         String   // text, image, html, zip, embedding
  storageUrl   String   @map("storage_url")
  fileName     String?  @map("file_name")
  sizeBytes    BigInt?  @map("size_bytes")
  metadata     Json?
  version      Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")

  generation    Generation     @relation(fields: [generationId], references: [id], onDelete: Cascade)
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assetCurrent  Asset[]        @relation("AssetCurrentArtifact")
  assetVersions AssetVersion[]
  deployments   Deployment[]

  @@index([projectId])
  @@index([generationId])
  @@index([type])
  @@map("artifacts")
}

// ─── ASSETS (reusable, versioned) ──────────────────────

model Asset {
  id                 String   @id @default(cuid())
  projectId          String   @map("project_id")
  orgId              String   @map("org_id")
  key                String
  currentArtifactId  String?  @map("current_artifact_id")
  createdBy          String?  @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")

  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  org              Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  currentArtifact  Artifact?      @relation("AssetCurrentArtifact", fields: [currentArtifactId], references: [id])
  creator          User?          @relation("AssetCreator", fields: [createdBy], references: [id])
  versions         AssetVersion[]

  @@unique([projectId, key])
  @@map("assets")
}

model AssetVersion {
  id         String   @id @default(cuid())
  assetId    String   @map("asset_id")
  artifactId String   @map("artifact_id")
  version    Int
  createdAt  DateTime @default(now()) @map("created_at")

  asset    Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([assetId, version])
  @@map("asset_versions")
}

// ─── DEPLOYMENTS ───────────────────────────────────────

model Deployment {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  artifactId   String?   @map("artifact_id")
  env          String    // staging, production
  provider     String    // vercel, netlify, aspire-cdn
  providerMeta Json?     @map("provider_meta")
  status       String    @default("pending") // pending, in_progress, succeeded, failed
  deployedAt   DateTime? @map("deployed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact Artifact? @relation(fields: [artifactId], references: [id])
  versions DeploymentVersion[]

  @@index([projectId, env])
  @@map("deployments")
}

model DeploymentVersion {
  id               String   @id @default(cuid())
  deploymentId     String   @map("deployment_id")
  artifactSnapshot Json?    @map("artifact_snapshot")
  createdAt        DateTime @default(now()) @map("created_at")

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@map("deployment_versions")
}

// ─── BILLING ───────────────────────────────────────────

model Plan {
  id         String   @id @default(cuid())
  key        String   @unique
  name       String
  priceCents BigInt   @map("price_cents")
  features   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String    @id @default(cuid())
  orgId                String    @map("org_id")
  planId               String    @map("plan_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  status               String    // active, canceled, past_due, trialing
  startedAt            DateTime? @map("started_at")
  canceledAt           DateTime? @map("canceled_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan Plan         @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model UsageRecord {
  id              String   @id @default(cuid())
  orgId           String   @map("org_id")
  projectId       String?  @map("project_id")
  generationId    String?  @map("generation_id")
  modelProvider   String?  @map("model_provider")
  modelName       String?  @map("model_name")
  tokensIn        BigInt   @default(0) @map("tokens_in")
  tokensOut       BigInt   @default(0) @map("tokens_out")
  embeddingsCount Int      @default(0) @map("embeddings_count")
  costCents       BigInt   @default(0) @map("cost_cents")
  recordedAt      DateTime @default(now()) @map("recorded_at")

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project    Project?     @relation(fields: [projectId], references: [id])
  generation Generation?  @relation(fields: [generationId], references: [id])

  @@index([orgId, recordedAt(sort: Desc)])
  @@map("usage_records")
}

model Invoice {
  id              String   @id @default(cuid())
  orgId           String   @map("org_id")
  invoiceDate     DateTime @map("invoice_date") @db.Date
  amountDueCents  BigInt   @map("amount_due_cents")
  stripeInvoiceId String?  @map("stripe_invoice_id")
  paid            Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("invoices")
}

model Payment {
  id           String    @id @default(cuid())
  invoiceId    String?   @map("invoice_id")
  orgId        String    @map("org_id")
  amountCents  BigInt    @map("amount_cents")
  providerMeta Json?     @map("provider_meta")
  paidAt       DateTime? @map("paid_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  invoice Invoice?     @relation(fields: [invoiceId], references: [id])
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── AUDIT / HISTORY ───────────────────────────────────

model ChangeHistory {
  id           String   @id @default(cuid())
  orgId        String?  @map("org_id")
  projectId    String?  @map("project_id")
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  action       String   // created, updated, deleted, published
  actorId      String?  @map("actor_id")
  diff         Json?
  createdAt    DateTime @default(now()) @map("created_at")

  org     Organization? @relation(fields: [orgId], references: [id])
  project Project?      @relation(fields: [projectId], references: [id])
  actor   User?         @relation("ChangeActor", fields: [actorId], references: [id])

  @@map("change_history")
}

model AuditLog {
  id           String   @id @default(cuid())
  orgId        String?  @map("org_id")
  actorId      String?  @map("actor_id")
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  details      Json?
  createdAt    DateTime @default(now()) @map("created_at")

  org   Organization? @relation(fields: [orgId], references: [id])
  actor User?         @relation("AuditActor", fields: [actorId], references: [id])

  @@map("audit_logs")
}

// ─── MODEL CATALOG ─────────────────────────────────────

model ModelCatalog {
  id           String   @id @default(cuid())
  provider     String
  modelName    String   @map("model_name")
  capabilities String[]
  costMetrics  Json?    @map("cost_metrics")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([provider, modelName])
  @@map("model_catalog")
}
